{
  "name": "balz-und-balz",
  "description": "Balz und Balz landing page based on Gatsby starter styled with Tailwind",
  "version": "2.0.0",
  "author": "Christian Rebelsky <christian.rebelskz@gmail.com>",
  "dependencies": {
    "gatsby": "2.25.3",
    "prop-types": "15.7.2",
    "react": "16.14.0",
    "react-dom": "16.14.0",
    "react-helmet": "6.1.0"
  },
  "keywords": [
    "gatsby",
    "tailwind",
    "tailwindcss",
    "purgecss"
  ],
  "license": "MIT",
  "scripts": {
    "analyze:lint": "eslint --ext .jsx --ext .js .",
    "analyze:prettier": "prettier --list-different \"**/*.{css,js,jsx,json,md}\"",
    "analyze": "npm run analyze:lint && npm run analyze:prettier",
    "fix:lint": "eslint --ext .jsx --ext .js . --fix",
    "fix:prettier": "prettier --write \"**/*.{css,js,jsx,json,md}\"",
    "fix": "npm run fix:lint && npm run fix:prettier",
    "build": "gatsby build",
    "develop": "gatsby develop",
    "dev": "npm run develop",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1"
  },
  "devDependencies": {
    "@svgr/webpack": "^5.5.0",
    "autoprefixer": "9.8.6",
    "babel-eslint": "10.1.0",
    "cssnano": "4.1.10",
    "eslint": "7.10.0",
    "eslint-loader": "4.0.2",
    "eslint-plugin-import": "2.22.1",
    "eslint-plugin-react": "7.21.5",
    "gatsby-plugin-eslint": "2.0.8",
    "gatsby-plugin-react-svg": "^3.0.0",
    "gatsby-plugin-svgr": "^2.0.2",
    "gatsby-plugin-manifest": "2.4.35",
    "gatsby-plugin-offline": "3.3.3",
    "gatsby-plugin-postcss": "2.3.13",
    "gatsby-plugin-react-helmet": "3.3.14",
    "gatsby-plugin-sharp": "2.7.1",
    "prettier": "2.1.2",
    "tailwindcss": "1.9.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/crebelsky/balz-balz"
  }
}
